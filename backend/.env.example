# ============================
# RTROM Backend - Environment
# ============================
# Copy this file to .env and fill in your values.

# Server
SERVER_PORT=8081

# PostgreSQL Database
DB_URL=jdbc:postgresql://localhost:5432/rtrom_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JPA / Hibernate
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# JWT Authentication
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRATION_MS=86400000
JWT_ISSUER=rtrom-backend
